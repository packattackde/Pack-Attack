# Pack-Attack Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials!

# ===========================================
# DATABASE (production: self-hosted PostgreSQL on dedicated server)
# ===========================================
# Pack-Attack production uses PostgreSQL 17 (Docker) on host 85.215.156.153 — NOT Neon.
# - Prod: port 5432, database packattackproddb
# - Dev (optional): port 5433, database packattackdevdb
# The Strato app server (82.165.66.236) must be allowed through firewall to reach 85.215.156.153:5432.
#
# Use the same host for both URLs; add pool params on DATABASE_URL if needed:
DATABASE_URL="postgresql://packattack:password@85.215.156.153:5432/packattackproddb?connection_limit=10&pool_timeout=30"
DIRECT_DATABASE_URL="postgresql://packattack:password@85.215.156.153:5432/packattackproddb"
#
# Optional — Neon or other hosted Postgres (only if you migrate off self-hosted):
# DATABASE_URL="postgresql://user:pass@host-pooler.region.aws.neon.tech/db?sslmode=require&connection_limit=10&pool_timeout=30"
# DIRECT_DATABASE_URL="postgresql://user:pass@host.region.aws.neon.tech/db?sslmode=require"
#
# Isolated LOCAL dev on Neon (branch): copy .neon.env.example to .neon.env, set NEON_API_KEY + NEON_PROJECT_ID, then:
#   npm run neon:dev-branch

# ===========================================
# AUTHENTICATION (NextAuth.js)
# ===========================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ===========================================
# ADMIN USER (for create-admin script)
# ===========================================
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your-secure-password-min-8-chars"
ADMIN_NAME="Admin User"

# ===========================================
# SERVER CONFIGURATION
# ===========================================
SERVER_IP="your-server-ip"
NODE_ENV="production"

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# ===========================================
# CARD APIs
# ===========================================
# JustTCG API for One Piece cards (get key from justtcg.com)
JUSTTCG_API_KEY="tcg_your_api_key_here"
